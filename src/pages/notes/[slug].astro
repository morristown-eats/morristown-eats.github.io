---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => data.published);
  return notes.map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { data } = note;
const { Content } = await note.render();

// Format date naturally
const dateObj = new Date(data.date + 'T12:00:00');
const dayOfWeek = dateObj.toLocaleDateString('en-US', { weekday: 'long' });
const monthDay = dateObj.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

// Neighborhood label
const neighborhoodLabel = data.neighborhood
  .split('-')
  .map((w: string) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');
---
<BaseLayout
  title={data.title}
  description={data.lede}
>
  <style>
    .note-wrap {
      max-width: 620px;
      padding: 3rem 0 6rem;
    }
    .note-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 1.25rem;
    }
    .note-type-badge {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: var(--color-rust);
      color: var(--color-paper);
      padding: 2px 8px;
      display: inline-block;
    }
    .note-date {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
    }
    .note-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3rem);
      line-height: 1.1;
      margin-bottom: 1.5rem;
      color: var(--color-ink);
    }
    .note-lede {
      font-family: var(--font-body);
      font-size: var(--text-lg);
      font-style: italic;
      line-height: 1.6;
      color: var(--color-ink);
      border-left: 3px solid var(--color-rust);
      padding-left: 1.25rem;
      margin-bottom: 2rem;
      max-width: 540px;
    }
    .note-body {
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: 1.8;
      color: var(--color-ink);
      margin-bottom: 2.5rem;
    }
    .note-body p {
      margin-bottom: 1rem;
    }
    .note-body p:first-of-type::first-letter {
      font-family: var(--font-display);
      font-size: 3.4em;
      float: left;
      line-height: 0.75;
      padding-right: 0.5rem;
      padding-top: 4px;
      color: var(--color-rust);
    }
    .note-footer {
      border-top: 2px solid var(--color-ink);
      padding-top: 1.5rem;
      margin-bottom: 2rem;
    }
    .note-footer-line {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      color: var(--color-ink-muted);
      line-height: 1.8;
    }
    .note-footer-line a {
      color: var(--color-rust);
      text-decoration: underline;
      text-decoration-style: dashed;
    }
    .note-vibe-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }
    .note-back {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-rust);
      text-decoration: underline;
      text-decoration-style: dashed;
    }
  </style>

  <div class="container">
    <div class="note-wrap">

      <!-- Back link -->
      <a href="/notes" class="note-back" style="display:inline-block; margin-bottom:2rem;">
        ← All Notes
      </a>

      <!-- Meta -->
      <div class="note-meta">
        <span class="note-type-badge">{data.noteTypeLabel}</span>
        <span class="note-date">{monthDay}</span>
      </div>

      <!-- Title -->
      <h1 class="note-title">{data.establishment}</h1>

      <!-- Lede -->
      <p class="note-lede">{data.lede}</p>

      <!-- Body -->
      <div class="note-body">
        <Content />
      </div>

      <!-- Footer info line -->
      <div class="note-footer">
        <p class="note-footer-line">
          <a href={`/restaurants/${data.establishmentSlug}`}>{data.establishment}</a> · {data.address} · {data.visitType} · {data.price}
        </p>
        {data.bestFor && (
          <p class="note-footer-line">Best for: {data.bestFor}</p>
        )}
        <div class="note-vibe-tags">
          {data.vibeTags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>

      <!-- Back to notes -->
      <a href="/notes" class="note-back">← All Notes</a>

    </div>
  </div>

</BaseLayout>
